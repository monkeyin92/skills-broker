          "producesArtifacts": ["code_change"],
          "nextStageId": "review",
          "requiresConfirmation": true
        },
        {
          "id": "review",
          "label": "Review the change",
          "kind": "capability",
          "capability": {
            "packageId": "gstack",
            "capabilityId": "gstack.review",
            "subskillId": "review",
            "implementationId": "gstack.review",
            "probe": {
              "manifestNames": ["review"],
              "aliases": ["gstack-review"]
            }
          },
          "requiresArtifacts": ["code_change"],
          "producesArtifacts": ["review_approved"],
          "nextStageId": "qa",
          "requiresConfirmation": true
        },
        {
          "id": "qa",
          "label": "QA the change",
          "kind": "capability",
          "capability": {
            "packageId": "gstack",
            "capabilityId": "gstack.qa",
            "subskillId": "qa",
            "implementationId": "gstack.qa",
            "probe": {
              "manifestNames": ["qa"],
              "aliases": ["gstack-qa"]
            }
          },
          "requiresArtifacts": ["code_change"],
          "producesArtifacts": ["qa_report"],
          "nextStageId": "ship",
          "requiresConfirmation": true
        },
        {
          "id": "ship",
          "label": "Ship the reviewed build",
          "kind": "host_native",
          "instructions": "Ship only after review and QA are complete.",
          "requiresArtifacts": ["review_approved", "qa_report"],
          "requiredCompletedStageIds": ["review", "qa"],
          "requiresConfirmation": true,
          "nextStageId": null
        }
      ]
