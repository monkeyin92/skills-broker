              "manifestNames": ["plan-eng-review"],
              "aliases": ["gstack-plan-eng-review"]
            }
          },
          "requiresArtifacts": ["design_doc", "ceo_review"],
          "producesArtifacts": ["execution_plan"],
          "nextStageId": "coding",
          "requiresConfirmation": true
        },
        {
          "id": "coding",
          "label": "Implement in the host",
          "kind": "host_native",
          "instructions": "Implement the approved execution plan in the current workspace.",
